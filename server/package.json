{
  "name": "rybbit-backend",
  "version": "2.6.0",
  "description": "Rybbit backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsc && node dist/index.js",
    "dev:cluster": "tsc && node dist/cluster.js",
    "build": "tsc && npm run build:analytics",
    "build:analytics": "cd src/analytics-script && node build.js",
    "start": "node dist/index.js",
    "start:cluster": "node dist/cluster.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:pull": "drizzle-kit pull --config=drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config=drizzle.config.ts",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "update:datacenter-asns": "node src/services/tracker/botBlocking/update-datacenter-asns.mjs",
    "update:referrer-spam": "node src/services/tracker/botBlocking/update-referrer-spam.mjs",
    "knip": "knip",
    "format": "prettier --write \"src/**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,json,md}\"",
    "backfill:lite-mvs": "tsc && node dist/scripts/backfillLiteDashboardMVs.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.842.0",
    "@axiomhq/pino": "^1.3.1",
    "@better-auth/api-key": "^1.5.5",
    "@better-auth/infra": "^0.1.12",
    "@better-auth/sso": "^1.5.5",
    "@clickhouse/client": "1.11.1",
    "@fastify/cors": "11.0.1",
    "@fastify/one-line-logger": "2.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "8.1.1",
    "@maxmind/geoip2-node": "6.1.0",
    "@mongodb-js/zstd": "^2.0.1",
    "@react-email/components": "1.0.1",
    "@react-email/tailwind": "2.0.1",
    "@rybbit/shared": "file:../shared",
    "better-auth": "1.5.5",
    "bullmq": "^5.56.5",
    "dotenv": "16.5.0",
    "drizzle-orm": "0.45.1",
    "fastify": "5.3.3",
    "i18n-iso-countries": "^7.14.0",
    "ip-address": "^10.0.1",
    "luxon": "3.7.2",
    "nanoid": "^5.1.6",
    "node-cache": "^5.1.2",
    "node-cron": "4.0.6",
    "pg": "8.16.0",
    "postgres": "3.4.5",
    "psl": "^1.15.0",
    "puppeteer": "^24.34.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "resend": "^4.5.1",
    "rrweb": "^2.0.0-alpha.20",
    "safe-regex2": "^5.0.0",
    "sqlstring": "2.3.3",
    "stripe": "18.1.0",
    "twilio": "^5.8.0",
    "ua-parser-js": "2.0.3",
    "undici": "^7.9.0",
    "web-vitals": "^5.0.3",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/luxon": "3.7.1",
    "@types/node": "^20.14.8",
    "@types/pg": "^8.15.1",
    "@types/psl": "^1.1.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sqlstring": "2.3.2",
    "drizzle-kit": "0.31.9",
    "esbuild": "^0.25.5",
    "jsdom": "^26.1.0",
    "knip": "^5.60.2",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.8.1",
    "terser": "^5.40.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
